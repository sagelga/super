{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "formFactor": "desktop",
        "screenEmulation": {
          "mobile": false,
          "width": 1350,
          "height": 940,
          "deviceScaleFactor": 1,
          "disabled": false
        }
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance":    ["warn",  {"minScore": 0.50}],
        "categories:accessibility":  ["error", {"minScore": 0.90}],
        "categories:best-practices": ["warn",  {"minScore": 0.90}],
        "categories:seo":            ["warn",  {"minScore": 0.85}],
        "first-contentful-paint":    ["warn",  {"maxNumericValue": 5000}],
        "total-blocking-time":       ["warn",  {"maxNumericValue": 1500}],
        "cumulative-layout-shift":   ["warn",  {"maxNumericValue": 0.50}],
        "largest-contentful-paint":  ["warn",  {"maxNumericValue": 15000}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
