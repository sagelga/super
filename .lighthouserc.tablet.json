{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "throttlingMethod": "simulate",
        "formFactor": "mobile",
        "screenEmulation": {
          "mobile": true,
          "width": 768,
          "height": 1024,
          "deviceScaleFactor": 2,
          "disabled": false
        }
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance":    ["warn", {"minScore": 0.45}],
        "categories:accessibility":  ["warn", {"minScore": 0.85}],
        "categories:best-practices": ["warn", {"minScore": 0.85}],
        "categories:seo":            ["warn", {"minScore": 0.80}],
        "first-contentful-paint":    ["warn", {"maxNumericValue": 5500}],
        "total-blocking-time":       ["warn", {"maxNumericValue": 2500}],
        "cumulative-layout-shift":   ["warn", {"maxNumericValue": 0.50}],
        "largest-contentful-paint":  ["warn", {"maxNumericValue": 22000}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
