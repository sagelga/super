{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "super",
    "compatibility_date": "2026-03-18",
    "account_id": "9124272a5c3e327f2e943bf27c0910c4",
    "compatibility_flags": ["nodejs_compat"],
    "main": ".open-next/worker.js",
    "placement": {
        "mode": "smart"
    },
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1
    },
    "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
    },
    "r2_buckets": [
        {
            "binding": "NEXT_INC_CACHE_R2_BUCKET",
            "bucket_name": "super-cache"
        }
    ],
    "kv_namespaces": [
        {
            "binding": "SUPER_CACHE",
            "id": "PLACEHOLDER_ID",
            "preview_id": "PLACEHOLDER_PREVIEW_ID"
        }
    ],
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "super-auth",
            "database_id": "b95d13f8-aca0-4962-b74c-e040d527a811"
        },
        {
            "binding": "CONTENT_DB",
            "database_name": "super-content",
            "database_id": "ae9eba62-7597-4150-b64c-5a5156b5270f"
        }
    ],
    "routes": [
    {
      "pattern": "sagelga.com",
      "custom_domain": true
    }
  ],
  "services": [
    {
      "binding": "SUPERBRAIN",
      "service": "superbrain-v2"
    }
  ]
}
